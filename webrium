<?php

// test

$paths = [
    __DIR__ . '/vendor/autoload.php',
    __DIR__ . '/../vendor/autoload.php',
];

$autoload = null;

foreach ($paths as $path) {
    if (file_exists($path)) {
        $autoload = $path;
        break;
    }
}

if ($autoload) {
    require $autoload;
} else {
    echo("Composer autoloader not found. Please run 'composer install' in your project root.\n");
    exit(1);
}

use Webrium\App;
use Webrium\Console\InitWebrium;
use Webrium\File;
use Webrium\Debug;
use Webrium\Directory;

use Webrium\Console\GenerateModel;
use Webrium\Console\GenerateController;
use Webrium\Console\GenerateRoute;
use Webrium\Console\CallController;
use Webrium\Console\InitBot;

use Webrium\Console\Plugin\PluginInstall;
use Webrium\Console\Plugin\PluginUpdate;
use Webrium\Console\Plugin\PluginRemove;
use Webrium\Console\Plugin\PluginList;
use Webrium\Console\Plugin\PluginInfo;
use Webrium\Console\Plugin\PluginNew;
use Webrium\Console\Plugin\PluginExport;

use Symfony\Component\Console\Application;


Debug::displayErrors(true);
Debug::initialize();
Directory::initDefaultStructure();
App::initialize(__DIR__);


$application = new Application('Webrium Console');

$application->add(new InitWebrium());
$application->add(new GenerateModel());
$application->add(new GenerateController());
$application->add(new GenerateRoute());
$application->add(new InitBot());
$application->add(new CallController());

// Plugin management commands
$application->add(new PluginInstall());
$application->add(new PluginUpdate());
$application->add(new PluginRemove());
$application->add(new PluginList());
$application->add(new PluginInfo());
$application->add(new PluginNew());
$application->add(new PluginExport());

$application->run();